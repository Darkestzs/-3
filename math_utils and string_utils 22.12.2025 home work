#math_utils

def factorial(n):
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result

def fibonacci(n):
    fibs = [0, 1]
    for i in range(2, n):
        fibs.append(fibs[-1] + fibs[-2])
    return fibs[:n]

def sum_of_digits(num):
    return sum(int(d) for d in str(abs(num)))

#string_utils 


    def is_palindrome(s):
    s = s.lower().replace(" ", "")
    return s == s[::-1]

def is_anagram(s1, s2):
    return sorted(s1.lower().replace(" ", "")) == sorted(s2.lower().replace(" ", ""))

def reverse_string(s):
    return s[::-1]
